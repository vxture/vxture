# 智能代理系统配置
# 用于配置LangGraph和AutoGen智能代理框架的设置

# 基础设置
DEBUG=true  # 全局调试模式
LOG_LEVEL=INFO  # 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_TO_FILE=true  # 是否记录到文件
LOG_FILE_PATH=./logs/agent.log  # 日志文件路径

# 智能代理框架选择
AGENT_FRAMEWORK=hybrid  # 可选值: langgraph, autogen, hybrid
PRIMARY_FRAMEWORK=langgraph  # 混合模式下的主要框架

# LLM提供商设置
DEFAULT_LLM_PROVIDER=openai  # 默认提供商 (openai, azure, anthropic, tongyi, ollama, deepseek)
AVAILABLE_LLM_PROVIDERS=openai,azure,anthropic,tongyi,ollama  # 可用提供商列表

# OpenAI设置
OPENAI_API_KEY=sk-xxx  # OpenAI API密钥
OPENAI_BASE_URL=https://api.openai.com/v1  # API基础URL
OPENAI_MODEL=gpt-4o  # 默认模型
OPENAI_ORGANIZATION=  # 组织ID (可选)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large  # 嵌入模型

# Azure OpenAI设置
AZURE_OPENAI_API_KEY=xxx  # Azure API密钥
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/  # Azure端点
AZURE_OPENAI_DEPLOYMENT=gpt-4  # 部署名称
AZURE_OPENAI_API_VERSION=2024-02-01  # API版本
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002  # 嵌入部署

# Anthropic设置
ANTHROPIC_API_KEY=sk-ant-xxx  # Anthropic API密钥
ANTHROPIC_MODEL=claude-3-opus-20240229  # 默认模型

# 阿里通义设置
DASHSCOPE_API_KEY=xxx  # 阿里通义千问API密钥
DASHSCOPE_MODEL=qwen-max  # 默认模型

# 其他LLM设置
OLLAMA_HOST=http://localhost:11434  # Ollama主机地址
OLLAMA_MODEL=llama3  # Ollama默认模型
DEEPSEEK_API_KEY=xxx  # DeepSeek API密钥

# LangGraph配置
LANGGRAPH_DEBUG=true  # 启用详细日志记录
LANGGRAPH_PERSISTENCE_ENABLED=true  # 启用状态持久化
LANGGRAPH_STORAGE_TYPE=redis  # 存储类型 (redis, filesystem, memory)
REDIS_URL=redis://localhost:6379/0  # Redis连接URL
LANGGRAPH_FILESYSTEM_PATH=./data/langgraph_states  # 文件系统存储路径
SESSION_TTL_SECONDS=86400  # 会话过期时间 (24小时)
GRAPH_VIZ_ENABLED=true  # 启用图可视化
GRAPH_VIZ_FORMAT=html  # 可视化格式 (html, json, mermaid)

# AutoGen配置
AUTOGEN_ENABLED=true  # 启用AutoGen
DEFAULT_AUTOGEN_MODEL=gpt-4o  # AutoGen默认模型
AUTOGEN_TEMPERATURE=0.1  # 温度设置
AUTOGEN_WORKFLOW=groupchat  # 工作流类型 (groupchat, sequential, custom)
AUTOGEN_HUMAN_INPUT_MODE=NEVER  # 人类输入模式 (NEVER, TERMINATE, ALWAYS)
AUTOGEN_DEFAULT_MAX_ROUNDS=15  # 最大轮次
AUTOGEN_USE_CACHE=true  # 使用缓存

# 群聊配置
GROUPCHAT_NAME=问题解决团队  # 群聊名称
GROUPCHAT_MAX_ROUND=15  # 最大轮次
SPEAKER_SELECTION=auto  # 发言者选择 (auto, round_robin, manual)
ALLOW_PARALLEL=false  # 允许并行执行
ENABLE_MEMORY=true  # 启用记忆

# 工具和检索设置
ENABLED_AGENT_TOOLS=web_search,file_operations,code_execution,human_feedback  # 启用的工具
CUSTOM_TOOLS_PATH=./app/agents/tools  # 自定义工具路径
TOOL_EXECUTION_TIMEOUT=60  # 工具执行超时时间
AGENT_FILESYSTEM_PATH=./data/workspace  # 代理文件系统路径
ALLOWED_CODE_LANGUAGES=python,javascript,bash  # 允许的代码执行语言

# RAG配置
RAG_ENABLED=true  # 启用检索增强生成
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5  # 嵌入模型
CHUNK_SIZE=1000  # 分块大小
CHUNK_OVERLAP=200  # 分块重叠
RETRIEVAL_K=5  # 检索数量
RERANK_ENABLED=true  # 启用重排序
RERANK_MODEL=BAAI/bge-reranker-large  # 重排序模型
RERANK_TOP_N=3  # 重排序保留数量

# 向量数据库设置
DEFAULT_VECTOR_STORE=pgvector  # 默认向量存储 (pgvector, chroma, qdrant, faiss)
PG_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/vxture  # PostgreSQL连接字符串
CHROMA_PERSIST_DIR=./data/chroma  # Chroma持久化目录
QDRANT_URL=http://localhost:6333  # Qdrant URL
FAISS_INDEX_PATH=./data/faiss  # FAISS索引路径

# 监控和跟踪
TRACING_ENABLED=true  # 启用跟踪
TRACING_TYPE=langsmith  # 跟踪类型 (langsmith, opentelemetry, custom)
LANGSMITH_API_KEY=  # LangSmith API密钥
LANGSMITH_PROJECT=vxture  # LangSmith项目名称

# API服务器设置
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,https://vxture.com
RATE_LIMIT_ENABLED=true  # 启用速率限制
RATE_LIMIT=100  # 每分钟请求数
