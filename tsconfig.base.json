{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,

    // Path aliases for monorepo packages
    "paths": {
      "@vxture/shared": ["./packages/shared/shared/dist/index.d.ts"],
      "@vxture/shared/*": ["./packages/shared/shared/dist/*"],

      "@vxture/design-system": ["./packages/design/design-system/src"],
      "@vxture/design-system/*": ["./packages/design/design-system/src/*"],
      "@vxture/core-api": ["./packages/core/api/src"],
      "@vxture/core-api/*": ["./packages/core/api/src/*"],

      "@vxture/core-config": ["./packages/core/config/dist/index.d.ts"],
      "@vxture/core-config/*": ["./packages/core/config/dist/*"],
      "@vxture/core-locale": ["./packages/core/locale/dist/index.d.ts"],
      "@vxture/core-locale/*": ["./packages/core/locale/dist/*"],

      "@vxture/core-tenant": ["./packages/core/tenant/src"],
      "@vxture/core-tenant/*": ["./packages/core/tenant/src/*"],

      "@vxture/core-auth": ["./packages/core/auth/dist/index.d.ts"],
      "@vxture/core-auth/*": ["./packages/core/auth/dist/*"],
      "@vxture/core-utils": ["./packages/core/utils/dist/index.d.ts"],
      "@vxture/core-utils/*": ["./packages/core/utils/dist/*"],

      "@vxture/ai-sdk": ["./packages/ai/ai-sdk/src"],
      "@vxture/ai-sdk/*": ["./packages/ai/ai-sdk/src/*"],
      "@vxture/service-ticket": ["./services/support/ticket/src"],
      "@vxture/service-ticket/*": ["./services/support/ticket/src/*"],
      "@vxture/service-billing": ["./services/commerce/billing/src"],
      "@vxture/service-billing/*": ["./services/commerce/billing/src/*"],
      "@vxture/service-subscription": ["./services/commerce/subscription/src"],
      "@vxture/service-subscription/*": ["./services/commerce/subscription/src/*"],
      "@vxture/platform-amap": ["./packages/platform/amap/src"],
      "@vxture/platform-amap/*": ["./packages/platform/amap/src/*"],
      "@vxture/platform-cesium": ["./packages/platform/cesium/src"],
      "@vxture/platform-cesium/*": ["./packages/platform/cesium/src/*"],
      "@vxture/platform-browser": ["./packages/platform/browser/src"],
      "@vxture/platform-browser/*": ["./packages/platform/browser/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", "build"]
}
