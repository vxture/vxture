{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@vxture/design-system": ["../../packages/design/design-system/src/client.ts"],
      "@vxture/design-system/tokens": ["../../packages/design/design-system/src/tokens-entry.ts"],
      "@vxture/design-system/types": ["../../packages/design/design-system/src/types-entry.ts"],
      "@vxture/design-system/server": ["../../packages/design/design-system/src/server.ts"]
    },
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": ["next-env.d.ts", "src", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
