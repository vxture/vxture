{
  "version": "1.2.0",
  "lastUpdated": "2026-05-01",
  "layers": [
    {
      "name": "shared",
      "packages": [
        "@vxture/shared"
      ],
      "location": "packages/shared/shared/",
      "responsibilities": [
        "pure utilities",
        "TypeScript types",
        "global constants"
      ],
      "allowed_dependencies": [
        "third-party libs only"
      ],
      "forbidden_dependencies": [
        "all internal packages"
      ]
    },
    {
      "name": "core",
      "packages": [
        "@vxture/core-api",
        "@vxture/core-auth",
        "@vxture/core-config",
        "@vxture/core-locale",
        "@vxture/core-tenant",
        "@vxture/core-utils"
      ],
      "location": "packages/core/{name}/",
      "responsibilities": [
        "platform infrastructure",
        "configuration management",
        "multi-tenant context",
        "i18n / locale",
        "API base infrastructure",
        "authentication primitives"
      ],
      "allowed_dependencies": [
        "shared"
      ],
      "forbidden_dependencies": [
        "service",
        "bff",
        "ai-sdk",
        "UI",
        "framework-specific packages"
      ]
    },
    {
      "name": "ai",
      "packages": [
        "@vxture/ai-sdk"
      ],
      "location": "packages/ai/ai-sdk/",
      "internal_modules": [
        "llm",
        "rag",
        "embedding",
        "workflow"
      ],
      "responsibilities": [
        "unified LLM client (Doubao, Claude, custom models)",
        "retrieval-augmented generation pipeline",
        "embedding and vectorization",
        "multi-step agent workflow orchestration"
      ],
      "allowed_dependencies": [
        "shared"
      ],
      "forbidden_dependencies": [
        "service",
        "bff",
        "UI",
        "platform"
      ]
    },
    {
      "name": "service",
      "packages": [
        "@vxture/service-billing",
        "@vxture/service-subscription",
        "@vxture/service-ticket"
      ],
      "location": "services/{domain}/{name}/",
      "domain_groups": {
        "commerce": [
          "@vxture/service-billing",
          "@vxture/service-subscription"
        ],
        "support": [
          "@vxture/service-ticket"
        ]
      },
      "naming_note": "Package names follow @vxture/service-{name}. Domain is directory-only and does not appear in the package name.",
      "responsibilities": [
        "shared platform domain logic",
        "business workflows",
        "service APIs",
        "promoted from agent-server when proven reusable"
      ],
      "allowed_dependencies": [
        "shared",
        "core"
      ],
      "forbidden_dependencies": [
        "other services",
        "bff",
        "ai-sdk",
        "UI",
        "platform"
      ]
    },
    {
      "name": "bff",
      "packages": [
        "@vxture/bff-website",
        "@vxture/bff-admin",
        "@vxture/bff-console",
        "@vxture/bff-vela",
        "@vxture/bff-agent{N}"
      ],
      "location": "bff/{name}-bff/",
      "responsibilities": [
        "authentication and session management",
        "tenant context resolution",
        "data aggregation across services and agent-server",
        "response shaping per consumer",
        "domain routing via router modules"
      ],
      "allowed_dependencies": [
        "agent-server (internal calls)",
        "service",
        "core",
        "shared"
      ],
      "forbidden_dependencies": [
        "other bff",
        "design-system",
        "platform",
        "ai-sdk"
      ]
    },
    {
      "name": "platform",
      "packages": [
        "@vxture/platform-amap",
        "@vxture/platform-cesium",
        "@vxture/platform-{name}"
      ],
      "location": "packages/platform/{name}/",
      "responsibilities": [
        "third-party client SDK wrappers",
        "typed React hooks and components",
        "coordinate system utilities",
        "version isolation from portal code"
      ],
      "allowed_dependencies": [
        "shared",
        "design-system (optional)"
      ],
      "forbidden_dependencies": [
        "core",
        "service",
        "bff",
        "ai-sdk"
      ]
    },
    {
      "name": "design",
      "packages": [
        "@vxture/design-system"
      ],
      "location": "packages/design/design-system/",
      "responsibilities": [
        "design tokens",
        "UI components",
        "theme system",
        "icon library",
        "density system",
        "global styles"
      ],
      "allowed_dependencies": [
        "shared"
      ],
      "forbidden_dependencies": [
        "core",
        "service",
        "bff",
        "ai-sdk",
        "platform"
      ]
    }
  ],
  "applications": {
    "portals": {
      "location": "portals/*",
      "examples": [
        "website",
        "admin",
        "console"
      ],
      "allowed_dependencies": [
        "bff (HTTP only)",
        "design-system",
        "platform",
        "shared"
      ],
      "forbidden_dependencies": [
        "service",
        "core",
        "ai-sdk",
        "bff (as package)"
      ]
    },
    "agent_studio": {
      "location": "agent-studio/*",
      "description": "Agent product frontends — fast-changing, customer-facing",
      "examples": [
        "ruyin",
        "vela"
      ],
      "packages": [
        "@vxture/agent-studio-vela"
      ],
      "allowed_dependencies": [
        "bff (HTTP only)",
        "design-system",
        "platform",
        "shared"
      ],
      "forbidden_dependencies": [
        "service",
        "core",
        "ai-sdk",
        "bff (as package)",
        "agent-server"
      ]
    },
    "agent_server": {
      "location": "agent-server/*",
      "description": "Agent-private backends — promotes to services when proven reusable",
      "examples": [
        "ruyin",
        "vela"
      ],
      "allowed_dependencies": [
        "ai-sdk",
        "service",
        "core",
        "shared"
      ],
      "forbidden_dependencies": [
        "other agent-server",
        "bff",
        "design-system",
        "platform"
      ]
    }
  },
  "agent_products": {
    "vela": {
      "description": "Productized embedded assistant for admin and console surfaces",
      "frontend": {
        "path": "agent-studio/vela",
        "package": "@vxture/agent-studio-vela",
        "embedded_in": [
          "portals/admin",
          "portals/console"
        ]
      },
      "bff": {
        "path": "bff/vela-bff",
        "package": "@vxture/bff-vela",
        "public_routes": [
          "/vela/chat"
        ]
      },
      "server": {
        "path": "agent-server/vela",
        "package": "vela-server",
        "internal_routes": [
          "/internal/vela/chat"
        ],
        "capabilities": [
          "CallerContext validation",
          "surface-aware tool registry",
          "LLM tool-use loop",
          "session and message persistence",
          "billing, subscription, and ticket service access"
        ]
      }
    }
  },
  "dependency_direction": [
    "portals/* --HTTP--> bff/* --> service --> core --> shared",
    "agent-studio/* --HTTP--> bff/* --> agent-server --> ai-sdk",
    "portals/admin and portals/console --embed--> agent-studio/vela --HTTP/SSE--> bff/vela-bff --> agent-server/vela",
    "portals/* and agent-studio/* --> design-system --> shared",
    "portals/* and agent-studio/* --> platform --> shared"
  ],
  "naming_conventions": {
    "packages": "@vxture/{group}-{name}",
    "package_path": "packages/{group}/{name}/",
    "services": "@vxture/service-{name}",
    "service_path": "services/{domain}/{name}/"
  },
  "workspace_config": {
    "file": "pnpm-workspace.yaml",
    "entries": [
      "portals/*",
      "agent-studio/*",
      "agent-server/*",
      "bff/*",
      "services/*/*",
      "packages/shared/shared",
      "packages/core/*",
      "packages/ai/ai-sdk",
      "packages/platform/*",
      "packages/design/design-system"
    ],
    "note": "services/*/* covers the two-level domain structure services/{domain}/{name}/"
  },
  "notes": {
    "ai_sdk": "Single package with internal modules: llm, rag, embedding, workflow. Server-side only.",
    "bff": "One BFF per consumer (portal or agent). Domain-split internally via router modules.",
    "vela": "Vela is an embedded agent product: admin and console host its UI, but all assistant traffic goes through @vxture/bff-vela and vela-server.",
    "agent_lifecycle": "agent-server logic promotes to services/{domain}/{name}/ when proven reusable across agents.",
    "service_domains": "services/ uses domain subdirectories for organization. Package names remain @vxture/service-{name}."
  }
}
