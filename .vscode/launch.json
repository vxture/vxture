{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Edge Browser",
      "type": "edge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${webRoot}/*"
      }
    },
    {
      "name": "Next.js: Node (pnpm)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI: Code Runner",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/packages/api/app/main.py",
      "console": "integratedTerminal",
      "env": {},
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Next.js: Fullstack (Edge)",
      "configurations": ["Next.js: Node (pnpm)", "Next.js: Edge Browser"]
    }
  ]
}
