{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Next.js (Node)",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}/packages/web",
      "remoteRoot": null,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Launch Next.js (dev)",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/web/node_modules/next/dist/bin/next",
      "args": ["dev"],
      "cwd": "${workspaceFolder}/packages/web",
      "console": "integratedTerminal",
      "runtimeArgs": ["--inspect=9229"],
      // 在启动前先运行工作区任务：pnpm: 启动前端 (web)
      "preLaunchTask": "pnpm: 启动前端 (web)"
    },
    {
      "name": "Python: FastAPI (uvicorn) - Run",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/packages/api/.venv/Scripts/uvicorn.exe",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/packages/api",
      // 可选：先运行后端 dev 任务（若你希望按 F5 启动后端可开启）
      "preLaunchTask": "pnpm: 启动后端 (api)"
    }
  ]
}
