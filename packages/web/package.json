{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:style": "stylelint \"src/**/*.scss\" --fix",
    "lint:ts": "eslint --fix 'src/**/*.{ts,tsx}'",
    "lint:all": "npm run lint && npm run lint:style && npm run type-check",
    "format": "prettier --write '**/*.{js,ts,tsx,json,md,scss}'",
    "format:check": "prettier --check '**/*.{js,ts,tsx,json,md,scss}'",
    "type-check": "tsc --noEmit",
    "check": "npm run lint:all && npm run format:check",
    "fix": "npm run lint:all && npm run format"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.3",
    "next": "^15.5.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "postcss": "^8.5.6",
    "postcss-custom-properties": "^14.0.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "stylelint": "^16.25.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  }
}
