{
  "name": "@vxture/core-utils",
  "version": "1.2.2",
  "description": "Vxture core utilities package",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@vxture/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
