{
  "name": "@vxture/core-tenant",
  "version": "1.2.2",
  "description": "Vxture platform — multi-tenant context management and tenant resolution",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "type-check": "tsc --noEmit",
