    "dev": "tsup --watch"
  },
  "dependencies": {
    "@vxture/shared": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/express":   "^5.0.0",
    "@swc/core":        "^1.10.0",    
    "reflect-metadata": "^0.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
