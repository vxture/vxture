// @package @vxture/core-database
// @layer  Infrastructure
// @category Database DDL — 平台手动维护 schema 的 Prisma 统一管理
//
// 覆盖范围（8 个 schema）：
//   identity — 10 张：account / account_credential / account_profile /
//                      sso_connection / oauth_provider / oauth_state /
//                      password_reset_token / account_session /
//                      account_verification / login_attempt
//   tenant   —  7 张：tenant / tenant_member / tenant_setting / tenant_domain /
//                      tenant_organization / tenant_ownership_transfer / tenant_invitation
//   iam      —  6 张：role / permission / role_permission /
//                      member_role_binding / capability / plan_capability
//   product  —  7 张：agent / agent_feature / feature / plan /
//                      plan_agent / plan_feature / plan_price
//   commerce — 12 张：tenant_invoice / tenant_invoice_item / tenant_invoice_receipt /
//                      tenant_payment / tenant_refund / tenant_subscription /
//                      tenant_subscription_history / tenant_subscription_override /
//                      tenant_transaction / tenant_credit /
//                      tenant_billing_address / tenant_payment_method
//   model    —  5 张：provider / model / model_grant / model_price_rule / model_policy
//   ops      —  9 张：admin / role / permission / role_permission / setting /
//                      governance_record / feature_flag / announcement / maintenance
//   support  —  4 张：ticket / ticket_event / audit_log / notification_log
//
// 排除（由 services/ai/gateway/prisma/schema.prisma 管理）：
//   commerce.tenant_subscription_quota
//   commerce.tenant_usage_event
//   commerce.tenant_usage_summary

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/core-database-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "tenant", "iam", "product", "commerce", "model", "ops", "support"]
}

// ═══════════════════════════════════════════════════════════════
// schema: identity
// ═══════════════════════════════════════════════════════════════

model Account {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username          String    @unique @db.VarChar(64)
  accountSource     String    @default("web") @map("account_source") @db.VarChar(32)
  status            String    @default("active") @db.VarChar(32)
  email             String?   @unique @db.VarChar(128)
  phone             String?   @unique @db.VarChar(32)
  emailVerifiedAt   DateTime? @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt   DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  loginCount        Int       @default(0) @map("login_count")
  loginFailureCount Int       @default(0) @map("login_failure_count")
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp       String?   @map("last_login_ip") @db.VarChar(64)
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  lockedUntil       DateTime? @map("locked_until") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  credential     AccountCredential?
  profile        AccountProfile?
  ssoConnections SsoConnection[]
  resetTokens    PasswordResetToken[]

  @@index([email], map: "idx_account_email")
  @@index([phone], map: "idx_account_phone")
  @@index([status], map: "idx_account_status")
  @@index([accountSource], map: "idx_account_source")
  @@index([deletedAt], map: "idx_account_deleted_at")
  @@map("account")
  @@schema("identity")
}

model AccountCredential {
  accountId           String    @id @map("account_id") @db.Uuid
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  mfaSecret           String?   @map("mfa_secret") @db.VarChar(255)
  mfaRecoveryCodes    String[]  @map("mfa_recovery_codes")
  forcePasswordChange Boolean   @default(false) @map("force_password_change")
  passwordChangedAt   DateTime? @map("password_changed_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_credential")
  @@schema("identity")
}

model AccountProfile {
  accountId   String    @id @map("account_id") @db.Uuid
  countryCode String?   @map("country_code") @db.Char(2)
  displayName String?   @map("display_name") @db.VarChar(96)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(512)
  headline    String?   @db.VarChar(128)
  bio         String?   @db.Text
  timezone    String?   @db.VarChar(64)
  language    String?   @db.VarChar(32)
  metadata    Json?     @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_profile")
  @@schema("identity")
}

model SsoConnection {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String    @map("account_id") @db.Uuid
  provider            String    @db.VarChar(32)
  providerAccountId   String    @map("provider_account_id") @db.VarChar(255)
  providerAccountData Json?     @map("provider_account_data") @db.JsonB
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, provider], map: "sso_connection_account_id_provider_key")
  @@unique([provider, providerAccountId], map: "sso_connection_provider_provider_account_id_key")
  @@index([accountId], map: "idx_sso_connection_account_id")
  @@index([provider], map: "idx_sso_connection_provider")
  @@index([providerAccountId], map: "idx_sso_connection_provider_account_id")
  @@index([deletedAt], map: "idx_sso_connection_deleted_at")
  @@map("sso_connection")
  @@schema("identity")
}

model OauthProvider {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique(map: "oauth_provider_code_key") @db.VarChar(64)
  name           String   @db.VarChar(64)
  clientId       String?  @map("client_id") @db.VarChar(255)
  clientSecret   String?  @map("client_secret") @db.VarChar(255)
  scope          String?  @db.VarChar(512)
  authUrl        String?  @map("auth_url") @db.VarChar(512)
  tokenUrl       String?  @map("token_url") @db.VarChar(512)
  accountInfoUrl String?  @map("account_info_url") @db.VarChar(512)
  redirectUri    String?  @map("redirect_uri") @db.VarChar(512)
  isEnabled      Boolean  @default(true) @map("is_enabled")
  sort           Int      @default(999)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled], map: "idx_oauth_provider_is_enabled")
  @@index([sort], map: "idx_oauth_provider_sort")
  @@map("oauth_provider")
  @@schema("identity")
}

// OAuth 授权请求状态，append-only
model OauthState {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerCode String   @map("provider_code") @db.VarChar(64)
  state        String   @unique(map: "oauth_state_state_key") @db.VarChar(128)
  redirectUri  String   @map("redirect_uri") @db.VarChar(512)
  codeVerifier String?  @map("code_verifier") @db.VarChar(128)
  nonce        String?  @db.VarChar(128)
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "idx_oauth_state_expires_at")
  @@index([providerCode], map: "idx_oauth_state_provider_code")
  @@map("oauth_state")
  @@schema("identity")
}

// 密码重置令牌，append-only
model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String    @map("account_id") @db.Uuid
  tokenHash String    @unique(map: "password_reset_token_token_hash_key") @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId], map: "idx_password_reset_token_account_id")
  @@index([expiresAt], map: "idx_password_reset_token_expires_at")
  @@map("password_reset_token")
  @@schema("identity")
}

// JWT 吊销黑名单，append-only
model AccountSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  jti          String   @unique(map: "account_session_jti_key") @db.VarChar(128)
  revokeReason String   @map("revoke_reason") @db.VarChar(64)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId], map: "idx_account_session_account_id")
  @@index([expiresAt], map: "idx_account_session_expires_at")
  @@map("account_session")
  @@schema("identity")
}

// 邮箱/手机验证码，append-only
model AccountVerification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String?   @map("account_id") @db.Uuid
  targetType   String    @map("target_type") @db.VarChar(16)
  target       String    @db.VarChar(128)
  purpose      String    @db.VarChar(32)
  codeHash     String    @map("code_hash") @db.VarChar(64)
  attemptCount Int       @default(0) @map("attempt_count")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId], map: "idx_account_verification_account_id")
  @@index([target, expiresAt], map: "idx_account_verification_target_expires")
  @@map("account_verification")
  @@schema("identity")
}

// 登录尝试记录，风控/限速，append-only
model LoginAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId   String?  @map("account_id") @db.Uuid
  identity    String   @db.VarChar(128)
  authMethod  String   @default("password") @map("auth_method") @db.VarChar(32)
  result      String   @db.VarChar(32)
  ipAddress   String   @map("ip_address") @db.VarChar(64)
  countryCode String?  @map("country_code") @db.Char(2)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([identity, createdAt(sort: Desc)], map: "idx_login_attempt_identity_created")
  @@index([ipAddress, createdAt(sort: Desc)], map: "idx_login_attempt_ip_created")
  @@index([accountId], map: "idx_login_attempt_account_id")
  @@map("login_attempt")
  @@schema("identity")
}

// ═══════════════════════════════════════════════════════════════
// schema: tenant
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantCode     String    @unique(map: "tenants_tenant_code_key") @map("tenant_code") @db.VarChar(64)
  tenantType     String    @map("tenant_type") @db.VarChar(32)
  status         String    @default("active") @db.VarChar(32)
  statusReason   String?   @map("status_reason") @db.VarChar(512)
  statusAt       DateTime? @map("status_at") @db.Timestamptz(6)
  tenantName     String    @map("tenant_name") @db.VarChar(128)
  displayName    String?   @map("display_name") @db.VarChar(128)
  description    String?   @db.VarChar(1024)
  logoUrl        String?   @map("logo_url") @db.VarChar(512)
  region         String    @default("cn-hangzhou") @db.VarChar(64)
  language       String    @default("zh-CN") @db.VarChar(16)
  timeZone       String    @default("Asia/Shanghai") @map("time_zone") @db.VarChar(64)
  source         String?   @db.VarChar(64)
  ownerAccountId String?   @map("owner_account_id") @db.Uuid
  isTrial        Boolean   @default(false) @map("is_trial")
  trialEndsAt    DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  convertedAt    DateTime? @map("converted_at") @db.Timestamptz(6)
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz(6)
  metadata       Json?     @db.JsonB
  createdBy      String?   @map("created_by") @db.Uuid
  approvedBy     String?   @map("approved_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  settings           TenantSetting[]
  domains            TenantDomain[]
  members            TenantMember[]
  organization       TenantOrganization?
  ownershipTransfers TenantOwnershipTransfer[]
  iamRoles           IamRole[]
  invitations        TenantInvitation[]

  @@index([createdBy], map: "idx_tenants_created_by")
  @@index([deletedAt], map: "idx_tenants_deleted_at")
  @@index([isTrial], map: "idx_tenants_is_trial")
  @@index([status], map: "idx_tenants_status")
  @@index([tenantName], map: "idx_tenants_tenant_name")
  @@index([tenantType], map: "idx_tenants_tenant_type")
  @@map("tenant")
  @@schema("tenant")
}

model TenantMember {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  accountId      String    @map("account_id") @db.Uuid
  role           String    @default("member") @db.VarChar(32)
  status         String    @default("active") @db.VarChar(32)
  joinedSource   String    @default("created") @map("joined_source") @db.VarChar(64)
  nickname       String?   @db.VarChar(128)
  remark         String?   @db.VarChar(512)
  invitedBy      String?   @map("invited_by") @db.Uuid
  isPrimaryOwner Boolean   @default(false) @map("is_primary_owner")
  joinedAt       DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  lastActiveAt   DateTime? @map("last_active_at") @db.Timestamptz(6)
  metadata       Json?     @db.JsonB
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  roleBindings IamMemberRoleBinding[]

  @@unique([tenantId, accountId], map: "tenant_members_tenant_id_user_id_key")
  @@index([accountId], map: "idx_tm_account_id")
  @@index([deletedAt], map: "idx_tm_deleted_at")
  @@index([isPrimaryOwner], map: "idx_tm_is_primary_owner")
  @@index([role], map: "idx_tm_role")
  @@index([status], map: "idx_tm_status")
  @@index([tenantId], map: "idx_tm_tenant_id")
  @@map("tenant_member")
  @@schema("tenant")
}

model TenantSetting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  configGroup String?   @map("config_group") @db.VarChar(100)
  configKey   String    @map("config_key") @db.VarChar(128)
  valueType   String    @default("string") @map("value_type") @db.VarChar(20)
  configValue String?   @map("config_value") @db.Text
  isSensitive Boolean   @default(false) @map("is_sensitive")
  isEncrypted Boolean   @default(false) @map("is_encrypted")
  isReadonly  Boolean   @default(false) @map("is_readonly")
  description String?   @db.VarChar(512)
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, configKey], map: "tenant_settings_tenant_id_config_key_key")
  @@index([configKey], map: "idx_tset_config_key")
  @@index([deletedAt], map: "idx_tset_deleted_at")
  @@index([tenantId, configGroup], map: "idx_tset_tenant_group")
  @@index([tenantId], map: "idx_tset_tenant_id")
  @@map("tenant_setting")
  @@schema("tenant")
}

model TenantDomain {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  domain             String    @unique(map: "tenant_domains_domain_key") @db.VarChar(256)
  domainType         String    @map("domain_type") @db.VarChar(32)
  verificationStatus String    @default("pending") @map("verification_status") @db.VarChar(32)
  sslStatus          String    @default("none") @map("ssl_status") @db.VarChar(32)
  verificationToken  String?   @map("verification_token") @db.VarChar(128)
  isPrimary          Boolean   @default(false) @map("is_primary")
  tokenExpiresAt     DateTime? @map("token_expires_at") @db.Timestamptz(6)
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([deletedAt], map: "idx_td_deleted_at")
  @@index([domain], map: "idx_td_domain")
  @@index([tenantId], map: "idx_td_tenant_id")
  @@map("tenant_domain")
  @@schema("tenant")
}

model TenantOrganization {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String    @unique(map: "tenant_organizations_tenant_id_key") @map("tenant_id") @db.Uuid
  countryCode             String    @default("CN") @map("country_code") @db.Char(2)
  companyName             String    @map("company_name") @db.VarChar(256)
  unifiedSocialCreditCode String?   @map("unified_social_credit_code") @db.VarChar(64)
  industry                String?   @db.VarChar(128)
  scale                   String?   @db.VarChar(64)
  province                String?   @db.VarChar(128)
  city                    String?   @db.VarChar(128)
  district                String?   @db.VarChar(128)
  postalCode              String?   @map("postal_code") @db.VarChar(16)
  address                 String?   @db.VarChar(512)
  contactName             String?   @map("contact_name") @db.VarChar(128)
  contactPhone            String?   @map("contact_phone") @db.VarChar(64)
  contactEmail            String?   @map("contact_email") @db.VarChar(128)
  businessLicenseUrl      String?   @map("business_license_url") @db.VarChar(512)
  verifiedStatus          String    @default("unverified") @map("verified_status") @db.VarChar(32)
  rejectedReason          String?   @map("rejected_reason") @db.VarChar(512)
  verifiedBy              String?   @map("verified_by") @db.Uuid
  verifiedAt              DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([deletedAt], map: "idx_to_deleted_at")
  @@index([tenantId], map: "idx_to_tenant_id")
  @@index([verifiedStatus], map: "idx_to_verified_status")
  @@map("tenant_organization")
  @@schema("tenant")
}

// 所有权转移记录，append-only
model TenantOwnershipTransfer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  operatorId     String   @map("operator_id") @db.Uuid
  fromAccountId  String   @map("from_account_id") @db.Uuid
  toAccountId    String   @map("to_account_id") @db.Uuid
  transferStatus String   @default("success") @map("transfer_status") @db.VarChar(32)
  transferReason String?  @map("transfer_reason") @db.VarChar(512)
  remark         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([fromAccountId], map: "idx_tot_from_account_id")
  @@index([tenantId], map: "idx_tot_tenant_id")
  @@index([toAccountId], map: "idx_tot_to_account_id")
  @@map("tenant_ownership_transfer")
  @@schema("tenant")
}

model TenantInvitation {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  targetType String    @map("target_type") @db.VarChar(16)
  target     String    @db.VarChar(128)
  role       String    @db.VarChar(32)
  status     String    @default("pending") @db.VarChar(32)
  tokenHash  String    @unique(map: "tenant_invitation_token_hash_key") @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdBy  String    @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "idx_tinv_tenant_id")
  @@index([status], map: "idx_tinv_status")
  @@index([expiresAt], map: "idx_tinv_expires_at")
  @@map("tenant_invitation")
  @@schema("tenant")
}

// ═══════════════════════════════════════════════════════════════
// schema: iam
// ═══════════════════════════════════════════════════════════════

model IamRole {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  roleCode    String    @map("role_code") @db.VarChar(64)
  roleName    String    @map("role_name") @db.VarChar(128)
  description String?   @db.VarChar(512)
  isSystem    Boolean   @default(false) @map("is_system")
  status      String    @default("active") @db.VarChar(16)
  sort        Int       @default(999)
  uiConfig    Json?     @map("ui_config") @db.JsonB
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  rolePermissions IamRolePermission[]
  memberBindings  IamMemberRoleBinding[]

  @@unique([tenantId, roleCode], map: "iam_role_tenant_id_role_code_key")
  @@index([deletedAt], map: "idx_iam_role_deleted_at")
  @@index([roleCode], map: "idx_iam_role_code")
  @@index([sort], map: "idx_iam_role_sort")
  @@index([status], map: "idx_iam_role_status")
  @@index([tenantId], map: "idx_iam_role_tenant_id")
  @@map("role")
  @@schema("iam")
}

model IamPermission {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permissionCode String    @unique(map: "iam_permission_code_key") @map("permission_code") @db.VarChar(128)
  module         String?   @db.VarChar(64)
  permissionType String    @default("function") @map("permission_type") @db.VarChar(32)
  permissionName String    @map("permission_name") @db.VarChar(128)
  parentCode     String?   @map("parent_code") @db.VarChar(128)
  description    String?   @db.VarChar(512)
  isActive       Boolean   @default(true) @map("is_active")
  isVisible      Boolean   @default(true) @map("is_visible")
  sort           Int       @default(999)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  rolePermissions IamRolePermission[]

  @@index([deletedAt], map: "idx_iam_perm_deleted_at")
  @@index([module], map: "idx_iam_perm_module")
  @@index([parentCode], map: "idx_iam_perm_parent_code")
  @@index([permissionCode], map: "idx_iam_perm_code")
  @@index([sort], map: "idx_iam_perm_sort")
  @@map("permission")
  @@schema("iam")
}

// 角色权限关联，复合主键，硬删除
model IamRolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       IamRole       @relation(fields: [roleId], references: [id])
  permission IamPermission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_iam_rp_permission_id")
  @@index([roleId], map: "idx_iam_rp_role_id")
  @@index([tenantId], map: "idx_iam_rp_tenant_id")
  @@map("role_permission")
  @@schema("iam")
}

// 成员→角色多对多绑定，硬删除
model IamMemberRoleBinding {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  memberId  String   @map("member_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  grantedBy String?  @map("granted_by") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  member TenantMember @relation(fields: [memberId], references: [id])
  role   IamRole      @relation(fields: [roleId], references: [id])

  @@unique([memberId, roleId], map: "iam_member_role_binding_member_role_key")
  @@index([memberId], map: "idx_iam_mrb_member_id")
  @@index([roleId], map: "idx_iam_mrb_role_id")
  @@index([tenantId], map: "idx_iam_mrb_tenant_id")
  @@map("member_role_binding")
  @@schema("iam")
}

model IamCapability {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capabilityCode String   @unique(map: "iam_capability_code_key") @map("capability_code") @db.VarChar(128)
  category       String   @db.VarChar(64)
  capabilityName String   @map("capability_name") @db.VarChar(128)
  description    String?  @db.VarChar(512)
  unit           String?  @db.VarChar(32)
  defaultLimit   BigInt?  @map("default_limit")
  isActive       Boolean  @default(true) @map("is_active")
  isMetered      Boolean  @default(false) @map("is_metered")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  planCapabilities IamPlanCapability[]

  @@index([category], map: "idx_iam_cap_category")
  @@index([isActive], map: "idx_iam_cap_is_active")
  @@map("capability")
  @@schema("iam")
}

// 订阅计划→能力集映射，复合主键，硬删除；planId 引用 product.plan
model IamPlanCapability {
  planId       String   @map("plan_id") @db.Uuid
  capabilityId String   @map("capability_id") @db.Uuid
  limitOverride BigInt? @map("limit_override")
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  capability IamCapability @relation(fields: [capabilityId], references: [id])

  @@id([planId, capabilityId])
  @@index([capabilityId], map: "idx_iam_pc_capability_id")
  @@index([planId], map: "idx_iam_pc_plan_id")
  @@map("plan_capability")
  @@schema("iam")
}

// ═══════════════════════════════════════════════════════════════
// schema: product（结构暂不变更，待单独详细设计）
// ═══════════════════════════════════════════════════════════════

model ProductAgent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentCode     String    @unique(map: "agent_code_key") @map("agent_code") @db.VarChar(64)
  agentName     String    @map("agent_name") @db.VarChar(128)
  description   String?   @db.Text
  agentType     String?   @default("chat") @map("agent_type") @db.VarChar(32)
  status        String    @default("draft") @db.VarChar(32)
  visibility    String    @default("public") @db.VarChar(32)
  agentCategory Int?      @default(0) @map("agent_category")
  tags          String[]  @default([])
  sort          Int?      @default(0)
  iconUrl       String?   @map("icon_url") @db.VarChar(512)
  configJson    Json?     @map("config_json") @db.JsonB
  version       Int       @default(1)
  createdBy     String    @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  features ProductAgentFeature[]
  plans    ProductPlanAgent[]

  @@index([agentCategory], map: "idx_agents_agent_category")
  @@index([agentCode], map: "idx_agents_agent_code")
  @@index([createdBy], map: "idx_agents_created_by")
  @@index([deletedAt], map: "idx_agents_deleted_at")
  @@index([status], map: "idx_agents_status")
  @@index([visibility], map: "idx_agents_visibility")
  @@map("agent")
  @@schema("product")
}

model ProductAgentFeature {
  agentId    String    @map("agent_id") @db.Uuid
  featureId  String    @map("feature_id") @db.Uuid
  isRequired Boolean?  @default(false) @map("is_required")
  status     Boolean?  @default(true)
  createdBy  String    @map("created_by") @db.Uuid
  updatedBy  String?   @map("updated_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  agent   ProductAgent   @relation(fields: [agentId], references: [id])
  feature ProductFeature @relation(fields: [featureId], references: [id])

  @@id([agentId, featureId])
  @@index([agentId], map: "idx_paf_agent_id")
  @@index([deletedAt], map: "idx_paf_deleted_at")
  @@index([featureId], map: "idx_paf_feature_id")
  @@map("agent_feature")
  @@schema("product")
}

model ProductFeature {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  featureCode String    @unique(map: "feature_code_key") @map("feature_code") @db.VarChar(128)
  featureName String    @map("feature_name") @db.VarChar(128)
  parentCode  String?   @map("parent_code") @db.VarChar(128)
  featureType String?   @default("function") @map("feature_type") @db.VarChar(32)
  description String?   @db.Text
  status      Boolean?  @default(true)
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  agentFeatures ProductAgentFeature[]
  planFeatures  ProductPlanFeature[]

  @@index([deletedAt], map: "idx_features_deleted_at")
  @@index([featureCode], map: "idx_features_feature_code")
  @@index([parentCode], map: "idx_features_parent_code")
  @@map("feature")
  @@schema("product")
}

model ProductPlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planCode    String    @unique(map: "plan_code_key") @map("plan_code") @db.VarChar(64)
  planName    String    @map("plan_name") @db.VarChar(128)
  description String?   @db.Text
  planType    String?   @default("normal") @map("plan_type") @db.VarChar(32)
  level       Int?      @default(0)
  isFree      Boolean?  @default(false) @map("is_free")
  isPublic    Boolean?  @default(true) @map("is_public")
  status      Boolean?  @default(true)
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  agents   ProductPlanAgent[]
  features ProductPlanFeature[]
  prices   ProductPlanPrice[]

  @@index([deletedAt], map: "idx_plans_deleted_at")
  @@index([planCode], map: "idx_plans_plan_code")
  @@index([status], map: "idx_plans_status")
  @@map("plan")
  @@schema("product")
}

model ProductPlanAgent {
  planId    String    @map("plan_id") @db.Uuid
  agentId   String    @map("agent_id") @db.Uuid
  isAllowed Boolean?  @default(true) @map("is_allowed")
  createdBy String    @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  plan  ProductPlan  @relation(fields: [planId], references: [id])
  agent ProductAgent @relation(fields: [agentId], references: [id])

  @@id([agentId, planId])
  @@index([agentId], map: "idx_ppa_agent_id")
  @@index([deletedAt], map: "idx_ppa_deleted_at")
  @@index([planId], map: "idx_ppa_plan_id")
  @@map("plan_agent")
  @@schema("product")
}

model ProductPlanFeature {
  planId      String    @map("plan_id") @db.Uuid
  featureId   String    @map("feature_id") @db.Uuid
  quotaValue  BigInt?   @default(0) @map("quota_value")
  isUnlimited Boolean?  @default(false) @map("is_unlimited")
  configJson  Json?     @map("config_json") @db.JsonB
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  plan    ProductPlan    @relation(fields: [planId], references: [id])
  feature ProductFeature @relation(fields: [featureId], references: [id])

  @@id([planId, featureId])
  @@index([deletedAt], map: "idx_ppf_deleted_at")
  @@index([featureId], map: "idx_ppf_feature_id")
  @@index([planId], map: "idx_ppf_plan_id")
  @@map("plan_feature")
  @@schema("product")
}

model ProductPlanPrice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  price         Decimal   @db.Decimal(18, 6)
  originalPrice Decimal?  @map("original_price") @db.Decimal(18, 6)
  currency      String    @default("CNY") @db.VarChar(10)
  periodType    String    @map("period_type") @db.VarChar(20)
  periodValue   Int       @map("period_value")
  sort          Int?      @default(100)
  status        Boolean?  @default(true)
  isDefault     Boolean?  @default(false) @map("is_default")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  deletedBy     String?   @map("deleted_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  plan ProductPlan @relation(fields: [planId], references: [id])

  @@unique([planId, periodType, deletedAt], map: "uk_plan_price_period")
  @@index([deletedAt], map: "idx_plan_price_deleted")
  @@index([planId], map: "idx_plan_price_plan_id")
  @@index([status], map: "idx_plan_price_status")
  @@map("plan_price")
  @@schema("product")
}

// ═══════════════════════════════════════════════════════════════
// schema: commerce（手动维护；quota/event/summary 由 gateway 管理）
// ═══════════════════════════════════════════════════════════════

model TenantInvoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  billNo         String    @unique(map: "tenant_bill_bill_no_key") @map("bill_no") @db.VarChar(64)
  subscriptionId String?   @map("subscription_id") @db.Uuid
  billCycle      String    @map("bill_cycle") @db.VarChar(8)
  cycleStartDate DateTime  @map("cycle_start_date") @db.Date
  cycleEndDate   DateTime  @map("cycle_end_date") @db.Date
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  discountAmount Decimal?  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  payableAmount  Decimal   @default(0) @map("payable_amount") @db.Decimal(12, 2)
  paidAmount     Decimal?  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  currency       String?   @default("CNY") @db.VarChar(16)
  billStatus     String    @default("unpaid") @map("bill_status") @db.VarChar(32)
  billType       String?   @default("normal") @map("bill_type") @db.VarChar(32)
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  paymentMethod  String?   @map("payment_method") @db.VarChar(64)
  transactionNo  String?   @map("transaction_no") @db.VarChar(128)
  operatorId     String?   @map("operator_id") @db.Uuid
  operateRemark  String?   @map("operate_remark") @db.Text
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  items    TenantInvoiceItem[]
  payments TenantPayment[]

  @@index([billCycle], map: "idx_ti_cycle")
  @@index([billNo], map: "idx_ti_invoice_no")
  @@index([billStatus], map: "idx_ti_status")
  @@index([deletedAt], map: "idx_ti_deleted_at")
  @@index([tenantId], map: "idx_ti_tenant_id")
  @@index([tenantId, billCycle], map: "idx_tenant_bill_tenant_cycle")
  @@map("tenant_invoice")
  @@schema("commerce")
}

model TenantInvoiceItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billId         String    @map("bill_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  agentId        String?   @map("agent_id") @db.Uuid
  featureId      String?   @map("feature_id") @db.Uuid
  subscriptionId String?   @map("subscription_id") @db.Uuid
  itemName       String    @map("item_name") @db.VarChar(128)
  itemType       String    @map("item_type") @db.VarChar(32)
  itemUnit       String?   @map("item_unit") @db.VarChar(64)
  quantity       Decimal?  @default(1) @db.Decimal(12, 4)
  unitPrice      Decimal?  @default(0) @map("unit_price") @db.Decimal(12, 4)
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  usageRecordId  String?   @map("usage_record_id") @db.Uuid
  remark         String?   @db.VarChar(512)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  invoice TenantInvoice @relation(fields: [billId], references: [id])

  @@index([agentId], map: "idx_tii_agent_id")
  @@index([billId], map: "idx_tii_invoice_id")
  @@index([deletedAt], map: "idx_tii_deleted_at")
  @@index([itemType], map: "idx_tii_item_type")
  @@index([tenantId], map: "idx_tii_tenant_id")
  @@map("tenant_invoice_item")
  @@schema("commerce")
}

model TenantInvoiceReceipt {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  billId              String    @map("bill_id") @db.Uuid
  invoiceNo           String    @unique(map: "tenant_bill_invoice_invoice_no_key") @map("invoice_no") @db.VarChar(64)
  invoiceType         String    @map("invoice_type") @db.VarChar(32)
  invoiceTaxType      String    @map("invoice_tax_type") @db.VarChar(32)
  invoiceTitle        String    @map("invoice_title") @db.VarChar(256)
  taxNo               String?   @map("tax_no") @db.VarChar(128)
  companyInfo         Json      @map("company_info") @db.JsonB
  bankInfo            Json?     @map("bank_info") @db.JsonB
  addressInfo         Json?     @map("address_info") @db.JsonB
  invoiceAmount       Decimal   @map("invoice_amount") @db.Decimal(12, 2)
  taxAmount           Decimal?  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  currency            String?   @default("CNY") @db.VarChar(16)
  invoiceStatus       String    @default("applying") @map("invoice_status") @db.VarChar(32)
  statusRemark        String?   @map("status_remark") @db.Text
  invoiceCode         String?   @map("invoice_code") @db.VarChar(64)
  invoiceElectronicNo String?   @map("invoice_electronic_no") @db.VarChar(64)
  invoiceFileUrl      String?   @map("invoice_file_url") @db.Text
  issuedAt            DateTime? @map("issued_at") @db.Timestamptz(6)
  expressCompany      String?   @map("express_company") @db.VarChar(64)
  expressNo           String?   @map("express_no") @db.VarChar(64)
  sendAt              DateTime? @map("send_at") @db.Timestamptz(6)
  createdBy           String    @map("created_by") @db.Uuid
  auditorId           String?   @map("auditor_id") @db.Uuid
  auditAt             DateTime? @map("audit_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([invoiceNo], map: "idx_tbi_invoice_no")
  @@index([invoiceStatus], map: "idx_tbi_invoice_status")
  @@map("tenant_invoice_receipt")
  @@schema("commerce")
}

model TenantPayment {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  billId               String    @map("bill_id") @db.Uuid
  transactionId        String    @map("transaction_id") @db.Uuid
  payOrderNo           String    @unique(map: "tenant_bill_payment_pay_order_no_key") @map("pay_order_no") @db.VarChar(64)
  paySource            String    @default("online") @map("pay_source") @db.VarChar(32)
  payChannel           String?   @map("pay_channel") @db.VarChar(32)
  payMethod            String?   @map("pay_method") @db.VarChar(32)
  offlinePayType       String?   @map("offline_pay_type") @db.VarChar(32)
  offlinePayerName     String?   @map("offline_payer_name") @db.VarChar(128)
  offlinePayTime       DateTime? @map("offline_pay_time") @db.Timestamptz(6)
  offlineEvidenceUrl   String?   @map("offline_evidence_url") @db.Text
  totalAmount          Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount           Decimal?  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  currency             String?   @default("CNY") @db.VarChar(16)
  payStatus            String    @default("pending") @map("pay_status") @db.VarChar(32)
  statusMsg            String?   @map("status_msg") @db.Text
  channelOrderNo       String?   @map("channel_order_no") @db.VarChar(128)
  channelTransactionNo String?   @map("channel_transaction_no") @db.VarChar(128)
  channelRawData       Json?     @map("channel_raw_data") @db.JsonB
  payExpireAt          DateTime? @map("pay_expire_at") @db.Timestamptz(6)
  paidAt               DateTime? @map("paid_at") @db.Timestamptz(6)
  closedAt             DateTime? @map("closed_at") @db.Timestamptz(6)
  operatorId           String?   @map("operator_id") @db.Uuid
  operateRemark        String?   @map("operate_remark") @db.Text
