// 订阅变更日志，append-only，不含 updated_at
model TenantSubscriptionHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  changeType     String   @map("change_type") @db.VarChar(32)
  fromPlanId     String?  @map("from_plan_id") @db.Uuid
  toPlanId       String?  @map("to_plan_id") @db.Uuid
  fromStatus     String?  @map("from_status") @db.VarChar(32)
  toStatus       String?  @map("to_status") @db.VarChar(32)
  operatorType   String   @default("system") @map("operator_type") @db.VarChar(32)
  operatorId     String?  @map("operator_id") @db.Uuid
  operatorRemark String?  @map("operator_remark") @db.VarChar(512)
  clientIp       String?  @map("client_ip") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([changeType], map: "idx_tscl_change_type")
  @@index([createdAt], map: "idx_tscl_created_at")
  @@index([subscriptionId], map: "idx_tscl_subscription_id")
  @@index([tenantId], map: "idx_tscl_tenant_id")
  @@map("tenant_subscription_history")
  @@schema("commerce")
}

