  @@index([deletedAt], map: "idx_tenants_deleted_at")
  @@index([status], map: "idx_tenants_status")
  @@index([tenantName], map: "idx_tenants_tenant_name")
  @@index([tenantType], map: "idx_tenants_tenant_type")
  @@map("tenant")
  @@schema("tenancy")
}

model TenantConfig {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  configKey   String    @map("config_key") @db.VarChar(128)
  configValue String?   @map("config_value") @db.Text
  isEncrypted Boolean?  @default(false) @map("is_encrypted")
  description String?   @db.VarChar(512)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
