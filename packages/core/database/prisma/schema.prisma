// @package @vxture/core-database
// @layer  Infrastructure
// @category Database DDL — 平台手动维护 schema 的 Prisma 统一管理
// @author AI-Generated
// @date   2026-05-04
//
// 覆盖范围（6 个 schema，39 张表）：
//   account  — 6 张：account / account_identity / account_oauth_provider /
//                     account_oauth_state / account_profile / password_reset_token
//   tenancy  — 9 张：tenant / tenant_config / tenant_domain / tenant_member /
//                     tenant_organization / tenant_ownership_transfer /
//                     tenant_permission / tenant_role / tenant_role_permission
//   product  — 7 张：agent / agent_feature / feature / plan /
//                     plan_agent / plan_feature / plan_price
//   platform — 5 张：platform_admin / platform_config / platform_permission /
//                     platform_role / platform_role_permission
//   support  — 2 张：ticket / ticket_event
//   commerce — 9 张：tenant_invoice / tenant_invoice_item / tenant_invoice_receipt /
//                     tenant_payment / tenant_refund / tenant_subscription /
//                     tenant_subscription_history / tenant_subscription_override /
//                     tenant_transaction
//
// 排除（由 services/ai/gateway/prisma/schema.prisma 管理）：
//   commerce.tenant_subscription_quota
//   commerce.tenant_usage_event
//   commerce.tenant_usage_summary

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/core-database-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["account", "tenancy", "product", "platform", "support", "commerce"]
}

// ═══════════════════════════════════════════════════════════════
// schema: account
// ═══════════════════════════════════════════════════════════════

model Account {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @db.VarChar(64)
  email        String?   @unique @db.VarChar(128)
  phone        String?   @unique @db.VarChar(32)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  status       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp  String?   @map("last_login_ip") @db.VarChar(64)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  identities  AccountIdentity[]
  profile     AccountProfile?
  resetTokens PasswordResetToken[]

  @@index([email], map: "idx_account_email")
  @@index([phone], map: "idx_account_phone")
  @@index([status], map: "idx_account_status")
  @@index([deletedAt], map: "idx_account_deleted_at")
  @@map("account")
  @@schema("account")
}

model AccountIdentity {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId           String    @map("account_id") @db.Uuid
  provider            String    @db.VarChar(32)
  providerAccountId   String    @map("provider_account_id") @db.VarChar(255)
  providerAccountData Json?     @map("provider_account_data") @db.JsonB
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, provider], map: "account_identities_account_id_provider_key")
  @@unique([provider, providerAccountId], map: "account_identities_provider_provider_account_id_key")
  @@index([accountId], map: "idx_account_identities_account_id")
  @@index([provider], map: "idx_account_identities_provider")
  @@index([providerAccountId], map: "idx_account_identities_provider_account_id")
  @@index([deletedAt], map: "idx_account_identities_deleted_at")
  @@map("account_identity")
  @@schema("account")
}

model AccountOauthProvider {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique(map: "oauth_providers_code_key") @db.VarChar(64)
  name           String   @db.VarChar(64)
  clientId       String?  @map("client_id") @db.VarChar(255)
  clientSecret   String?  @map("client_secret") @db.VarChar(255)
  scope          String?  @db.VarChar(512)
  authUrl        String?  @map("auth_url") @db.VarChar(512)
  tokenUrl       String?  @map("token_url") @db.VarChar(512)
  accountInfoUrl String?  @map("account_info_url") @db.VarChar(512)
  redirectUri    String?  @map("redirect_uri") @db.VarChar(512)
  isEnabled      Boolean  @default(true) @map("is_enabled")
  sort           Int      @default(999)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled], map: "oauth_providers_is_enabled_idx")
  @@index([sort], map: "oauth_providers_sort_idx")
  @@map("account_oauth_provider")
  @@schema("account")
}

// OAuth 授权请求状态，不含 updated_at（append-only 语义）
model AccountOauthState {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  state        String   @unique(map: "oauth_states_state_key") @db.VarChar(128)
  providerCode String   @map("provider_code") @db.VarChar(64)
  redirectUri  String   @map("redirect_uri") @db.VarChar(512)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "oauth_states_expires_at_idx")
  @@index([providerCode], map: "oauth_states_provider_code_idx")
  @@map("account_oauth_state")
  @@schema("account")
}

// 账号扩展资料，以 account_id 为主键（一对一）
model AccountProfile {
  accountId   String    @id @map("account_id") @db.Uuid
  displayName String?   @map("display_name") @db.VarChar(96)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(512)
  headline    String?   @db.VarChar(128)
  bio         String?   @db.Text
  timezone    String?   @db.VarChar(64)
  language    String?   @db.VarChar(32)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_profile")
  @@schema("account")
}

// 密码重置令牌，不含 updated_at（token 只写入一次，used_at 记录使用状态）
model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String    @map("account_id") @db.Uuid
  tokenHash String    @unique(map: "password_reset_token_token_hash_key") @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId], map: "idx_password_reset_token_account_id")
  @@index([expiresAt], map: "idx_password_reset_token_expires_at")
  @@map("password_reset_token")
  @@schema("account")
}

