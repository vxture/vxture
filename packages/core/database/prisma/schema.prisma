  expiresAt         DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy         String?   @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@unique([modelId, tenantId], map: "model_policy_model_tenant_key")
  @@index([isActive], map: "idx_model_policy_is_active")
  @@index([modelId], map: "idx_model_policy_model")
  @@index([tenantId], map: "idx_model_policy_tenant")
  @@map("model_policy")
  @@schema("model")
}

