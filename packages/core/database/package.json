{
  "name": "@vxture/core-database",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Vxture platform — unified DDL management via Prisma (account / tenancy / product / platform / support / commerce)",
  "scripts": {
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:pull": "prisma db pull --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
