// 用于 tsc 独立生成类型声明，或作为 tsup dts 的备用配置
// 当前由 tsup dts: true 负责生成 .d.ts，此文件供备用/CI 类型验证使用

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
