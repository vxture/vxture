generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["commerce", "model"]
}

// model schema 的 DDL 由 packages/core/database/prisma/schema.prisma 统一管理。
// 本文件在 model schema 中额外声明 ModelDefinition / ModelGrant 以生成 Prisma Client 代理，
// 供 ModelRegistryRepository 在 gateway 服务内直接查询，无需跨服务 RPC。
// commerce schema 中保留 gateway 独有的配额/用量统计表。

model TenantSubscriptionQuota {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @unique @map("tenant_id") @db.Uuid
  subscriptionId     String?   @map("subscription_id") @db.Uuid
  maxUsers           Int       @default(10) @map("max_users")
  maxApiKeys         Int       @default(5) @map("max_api_keys")
  maxWorkflows       Int       @default(20) @map("max_workflows")
  maxConcurrent      Int       @default(5) @map("max_concurrent")
  rateLimitPerMinute Int       @default(60) @map("rate_limit_per_minute")
  periodTokens       BigInt    @default(1000000) @map("period_tokens")
  quotaCycle         String    @default("monthly") @map("quota_cycle") @db.VarChar(32)
  allowedModels      String[]  @default([]) @map("allowed_models")
  allowCustomModel   Boolean   @default(false) @map("allow_custom_model")
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  effectiveAt        DateTime  @map("effective_at") @db.Timestamptz(6)
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)

  @@index([tenantId], map: "idx_tsq_tenant_id")
  @@index([subscriptionId], map: "idx_tsq_subscription_id")
  @@map("tenant_subscription_quota")
  @@schema("commerce")
}

model TenantUsageEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  featureId   String   @map("feature_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  usedQuota   BigInt   @default(0) @map("used_quota")
  inputQuota  BigInt?  @default(0) @map("input_quota")
  outputQuota BigInt?  @default(0) @map("output_quota")
  requestId   String?  @map("request_id") @db.VarChar(128)
  businessId  String?  @map("business_id") @db.VarChar(128)
  usageType   String   @default("normal") @map("usage_type") @db.VarChar(32)
  cycleDate   DateTime @map("cycle_date") @db.Date
  cycleMonth  String   @map("cycle_month") @db.VarChar(6)
  modelCode   String?  @map("model_code") @db.VarChar(64)
  latencyMs   Int?     @map("latency_ms")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([agentId], map: "idx_tue_agent_id")
  @@index([cycleDate], map: "idx_tue_cycle_date")
  @@index([cycleMonth], map: "idx_tue_cycle_month")
  @@index([featureId], map: "idx_tue_feature_id")
  @@index([modelCode], map: "idx_tue_model_code")
  @@index([requestId], map: "idx_tue_request_id")
  @@index([tenantId], map: "idx_tue_tenant_id")
  @@index([userId], map: "idx_tue_user_id")
  @@index([tenantId, cycleMonth], map: "idx_tue_tenant_month")
  @@map("tenant_usage_event")
  @@schema("commerce")
}

model TenantUsageSummary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  featureId    String   @default("00000000-0000-0000-0000-000000000000") @map("feature_id") @db.Uuid
  agentId      String   @default("00000000-0000-0000-0000-000000000000") @map("agent_id") @db.Uuid
  cycleMonth   String   @map("cycle_month") @db.VarChar(6)
  totalQuota   BigInt   @default(0) @map("total_quota")
  inputQuota   BigInt   @default(0) @map("input_quota")
  outputQuota  BigInt   @default(0) @map("output_quota")
  requestCount BigInt   @default(0) @map("request_count")
  lastSyncedAt DateTime @default(now()) @map("last_synced_at") @db.Timestamptz(6)
  statType     String   @default("detail") @map("stat_type") @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, featureId, agentId, cycleMonth, statType], map: "tenant_usage_summary_unique")
  @@index([agentId], map: "idx_tus_agent_id")
  @@index([cycleMonth], map: "idx_tus_cycle_month")
  @@index([featureId], map: "idx_tus_feature_id")
  @@index([statType], map: "idx_tus_stat_type")
  @@index([tenantId], map: "idx_tus_tenant_id")
  @@index([tenantId, cycleMonth], map: "idx_tus_tenant_month")
  @@map("tenant_usage_summary")
  @@schema("commerce")
}

// ── model schema（只读代理，DDL 由 packages/core/database 管理） ──

model ModelDefinition {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId       String?   @map("provider_id") @db.Uuid
  modelCode        String    @unique @map("model_code") @db.VarChar(128)
  provider         String    @db.VarChar(64)
  modelType        String    @default("chat") @map("model_type") @db.VarChar(32)
  protocol         String    @db.VarChar(64)
  modelName        String    @map("model_name") @db.VarChar(128)
  description      String?   @db.VarChar(512)
  endpointUrl      String    @map("endpoint_url") @db.Text
  contextWindow    Int?      @map("context_window")
  maxOutputTokens  Int?      @map("max_output_tokens")
  capabilities     String[]  @default([])
  supportsStreaming Boolean   @default(true) @map("supports_streaming")
  isActive         Boolean   @default(true) @map("is_active")
  sort             Int       @default(999)
  config           Json?     @db.JsonB
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  grants ModelGrant[]

  @@index([isActive], map: "idx_model_def_is_active")
  @@index([provider], map: "idx_model_def_provider")
  @@map("model")
  @@schema("model")
}

model ModelGrant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId   String    @map("model_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  agentId   String?   @map("agent_id") @db.Uuid
  priority  Int       @default(100)
  isActive  Boolean   @default(true) @map("is_active")
  reason    String?   @db.VarChar(512)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  modelDef ModelDefinition @relation(fields: [modelId], references: [id])

  @@index([modelId], map: "idx_model_grant_model")
  @@index([tenantId], map: "idx_model_grant_tenant")
  @@index([isActive], map: "idx_model_grant_is_active")
  @@map("model_grant")
  @@schema("model")
}
