    "typescript",
    "typescriptreact",
    "upstash",
    "uvicorn",
    "venv",
    "vercel",
    "vxture",
    "zustand"
  ],
  "dictionaries": ["typescript", "node", "npm", "html", "css"],
  "ignorePaths": [
    "node_modules/**",
    ".next/**",
    "dist/**",
    "build/**",
    "**/*.min.js",
    "**/*.min.css",
    "coverage/**",
    ".venv/**",
    "__pycache__/**",
    "*.pyc",
    "pnpm-lock.yaml"
  ],
  "overrides": [
    {
      "filename": "**/*.py",
      "dictionaries": ["python"],
      "words": [
        "fastapi",
        "uvicorn",
        "pydantic",
        "alembic",
        "psycopg",
        "asyncio",
        "dotenv",
        "httpx",
        "pytest",
        "aiofiles"
      ]
    },
    {
      "filename": "**/*.{ts,tsx,js,jsx}",
      "dictionaries": ["typescript", "node", "npm"],
      "words": [
        "nextjs",
        "tailwindcss",
        "tanstack",
        "zustand",
        "autoprefixer",
        "postcss"
      ]
    },
    {
      "filename": "**/*.{css,scss}",
      "dictionaries": ["css"],
      "words": ["tailwindcss", "autoprefixer", "postcss"]
    },
    {
      "filename": "**/*.md",
      "dictionaries": ["en"],
      "words": ["monorepo", "vxture"]
    }
  ],
  "allowCompoundWords": true,
  "caseSensitive": false
}
