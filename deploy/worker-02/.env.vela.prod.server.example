# deploy/worker-02/.env.vela.prod.server
# vela-server 生产环境容器变量
# 复制本文件为 .env.vela.prod.server，填写真实值。

NODE_ENV=production
VELA_SERVER_PORT=3122

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vela:CHANGE_ME@vx-vela-pg-prod:5432/vela_prod

# ── AI Gateway（host.docker.internal 访问宿主机 127.0.0.1）──────────────────
AI_GATEWAY_URL=http://host.docker.internal:3100

# ── LLM 配置 ──────────────────────────────────────────────────────────────────
VELA_DEFAULT_MODEL_CODE=doubao-seed-2-0-lite-260215
# 平台运营租户 UUID（admin surface 调用计费归因）
VELA_PLATFORM_LLM_TENANT_ID=CHANGE_ME_UUID
