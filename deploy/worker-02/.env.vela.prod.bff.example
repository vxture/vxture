# deploy/worker-02/.env.vela.prod.bff
# vela-bff 生产环境容器变量
# 复制本文件为 .env.vela.prod.bff，填写真实值。

NODE_ENV=production
VELA_BFF_PORT=3121

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vela:CHANGE_ME@vx-vela-pg-prod:5432/vela_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@vx-vela-redis-prod:6379

# ── JWT（与平台 auth-bff 共用同一密钥）───────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MIN
AUTH_COOKIE_DOMAIN=.vxture.com

# ── 平台 auth-bff（JWT 验证，Tailscale 访问）──────────────────────────────────
AUTH_BFF_URL=http://100.100.197.42:3090
AUTH_INTERNAL_TOKEN=CHANGE_ME_RANDOM_TOKEN

# ── Vela Server（同 Compose 网络内部）────────────────────────────────────────
VELA_SERVER_INTERNAL_URL=http://vx-vela-server-prod:3122
