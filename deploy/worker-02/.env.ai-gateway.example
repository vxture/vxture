# deploy/worker-02/.env.ai-gateway
# ai-gateway 容器环境变量
# 复制本文件为 .env.ai-gateway，填写真实值。

NODE_ENV=production
AI_GATEWAY_PORT=3100

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aigateway:CHANGE_ME@vx-ai-gateway-pg:5432/ai_gateway

# ── AI 模型凭证 ───────────────────────────────────────────────────────────────
DOUBAO_API_KEY=CHANGE_ME

# 可选
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=
