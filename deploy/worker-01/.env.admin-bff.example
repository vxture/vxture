# deploy/worker-01/.env.admin-bff
# admin-bff 容器环境变量（平台运营管理）
# 复制本文件为 .env.admin-bff，填写真实值。

NODE_ENV=production
ADMIN_BFF_PORT=3031

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vxture:CHANGE_ME@vx-platform-pg:5432/platform_main
DB_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@vx-platform-redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
AUTH_COOKIE_DOMAIN=.vxture.com

# ── 内部服务地址 ──────────────────────────────────────────────────────────────
AUTH_BFF_URL=http://vx-auth-bff:3090
AUTH_INTERNAL_TOKEN=CHANGE_ME_RANDOM_TOKEN

# ── AI Gateway ────────────────────────────────────────────────────────────────
# worker-01 通过 Tailscale 访问 worker-02 的 ai-gateway
AI_GATEWAY_URL=http://100.76.219.48:3100

# ── 邮件（付款核销/驳回通知）────────────────────────────────────────────────
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=no-reply@mail.vxture.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="Vxture Studio" <no-reply@mail.vxture.com>
