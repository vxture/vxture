# deploy/worker-01/secrets/platform.env
# 平台级共享密钥 — 由 setup-env.sh 自动生成，禁止提交到 git
#
# 注入到所有需要数据库/Redis/JWT 的 BFF 服务容器中
# compose.platform.yml 中通过 env_file: [secrets/platform.env, .env.service] 加载

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vxture:CHANGE_ME@vx-platform-pg:5432/platform_main

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@vx-platform-redis:6379

# ── JWT（所有 BFF 共用同一签名密钥）─────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_32_CHARS_MIN

# ── 内部服务令牌（BFF 间调用鉴权）────────────────────────────────────────────
AUTH_INTERNAL_TOKEN=CHANGE_ME_RANDOM_TOKEN
