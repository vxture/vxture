# deploy/worker-01/.env.ai-gateway
# ai-gateway 容器环境变量（AI 模型调度服务）
# 复制本文件为 .env.ai-gateway，填写真实值。

NODE_ENV=production
AI_GATEWAY_PORT=3100

# ── 数据库 ────────────────────────────────────────────────────────────────────
# 密码须与 secrets/platform_pg_password.txt 一致
DATABASE_URL=postgresql://vxture:CHANGE_ME@vx-platform-pg:5432/platform_main

# ── Provider API Key 环境变量（按实际接入的模型填写）────────────────────────
# 在 AI 模型注册记录中 apiKeyEnvVar 字段填写的变量名必须在此配置
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DOUBAO_API_KEY=...
