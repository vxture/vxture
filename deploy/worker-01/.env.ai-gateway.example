# deploy/worker-01/.env.ai-gateway
# ai-gateway 容器环境变量（AI 模型调度服务）
# DATABASE_URL 由 secrets/platform.env 自动注入，无需在此配置

NODE_ENV=production
AI_GATEWAY_PORT=3100

# ── Provider API Keys（按实际接入的模型填写）────────────────────────────────
# 在 AI 模型注册记录中 apiKeyEnvVar 字段填写的变量名必须在此配置
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DOUBAO_API_KEY=...
