pipeline {
  agent any
  environment {
    REGISTRY = "registry.cn-hangzhou.aliyuncs.com/your-repo"
    DOCKER_CREDENTIALS_ID = "aliyun-docker-cred"
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Install') {
      steps {
        sh 'npm i -g pnpm || true'
        sh 'pnpm install'
      }
    }
    stage('Test') {
      steps {
        sh 'pnpm lint || true'
        sh 'pnpm test || true'
      }
    }
    stage('Build') {
      steps {
        sh 'pnpm --filter web build'
      }
    }
    stage('Docker Build & Push') {
      steps {
        script {
          sh 'docker build -t ${REGISTRY}/web:${GIT_COMMIT} -f infra/frontend/Dockerfile .'
          withCredentials([usernamePassword(credentialsId: DOCKER_CREDENTIALS_ID, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
            sh 'echo $DOCKER_PASS | docker login --username $DOCKER_USER --password-stdin ${REGISTRY}'
            sh 'docker push ${REGISTRY}/web:${GIT_COMMIT}'
          }
        }
      }
    }
  }
}
