name: CI  # 仅一个顶级名称

# 触发条件：main分支的push和PR
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build:
    name: "Full Build (Frontend + Backend)"
    runs-on: ubuntu-latest
    steps:
      # 1. 拉取代码
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. 配置Node.js环境（前端）
      - name: Setup Node.js (LTS)
        uses: actions/setup-node@v4
        with:
          node-version: 'lts'

      # 3. 配置pnpm（统一用官方action，版本稳定）
      - name: Setup pnpm (v8)
        uses: pnpm/action-setup@v3
        with:
          version: '8'

      # 4. 安装前端依赖
      - name: Install frontend dependencies
        run: pnpm install --frozen-lockfile

      # 5. 前端代码检查
      - name: Frontend Type-Check (full repo)
        run: pnpm -w -r type-check
      - name: Frontend Lint (code style)
        run: pnpm -w -r lint

      # 6. 可选：后端Python测试（先判断目录是否存在，避免报错）
      - name: Setup Python 3.13 (backend)
        uses: actions/setup-python@v4
        with:
          python-version: '3.13'

      - name: Install backend dependencies (if backend exists)
        run: |
          if [ -d "packages/api" ]; then
            cd packages/api
            python -m venv .venv
            . .venv/bin/activate
            pip install -r requirements.txt || true  # 安装失败不中断流程
          else
            echo "No backend directory found, skipping backend dependency installation."
          fi

      - name: Run backend tests (if backend exists)
        run: |
          if [ -d "packages/api" ]; then
            cd packages/api
            . .venv/bin/activate
            if [ -f pytest.ini ] || ls tests 1> /dev/null 2>&1; then
              pytest -q || true  # 测试失败不中断（可根据需求去掉|| true）
            else
              echo "No backend tests found, skip."
            fi
          else
            echo "No backend directory found, skipping backend tests."
          fi
