#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 检查提交消息是否遵循常规提交格式
# 例如: feat: 添加新功能, fix: 修复问题, docs: 更新文档
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat $COMMIT_MSG_FILE)

COMMIT_PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|wip)(\(.+\))?: .+"

if ! [[ $COMMIT_MSG =~ $COMMIT_PATTERN ]]; then
  echo "提交消息不符合规范。请使用以下格式:"
  echo "  <类型>(<可选范围>): <描述>"
  echo ""
  echo "类型必须是以下之一:"
  echo "  feat:     新功能"
  echo "  fix:      修复Bug"
  echo "  docs:     文档更新"
  echo "  style:    代码格式（不影响代码运行的变动）"
  echo "  refactor: 重构（既不修复bug也不添加特性的代码更改）"
  echo "  perf:     性能优化"
  echo "  test:     添加或修改测试"
  echo "  build:    构建工具或外部依赖的更改"
  echo "  ci:       CI配置文件和脚本的更改"
  echo "  chore:    其他修改"
  echo "  revert:   恢复之前的提交"
  echo "  wip:      进行中的工作"
  echo ""
  echo "例如:"
  echo "  feat: 添加用户登录功能"
  echo "  fix(auth): 修复登录失败问题"
  exit 1
fi
