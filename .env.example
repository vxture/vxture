# ═══════════════════════════════════════════════════════════════════════════════
# Vxture — 环境变量模板（根目录统一管理）
# 复制本文件为 .env.local，填入真实值后启动。
# .env.local 已加入 .gitignore，严禁提交含真实密钥的文件。
# ─────────────────────────────────────────────────────────────────────────────
# 覆盖范围：所有 BFF / Agent Server / AI Gateway（从根目录启动时自动读取）
# dev-panel 会把本文件派生出的根目录 .env.local 注入各服务；若直接进入 portal 运行 Next，
# 需要确保 NEXT_PUBLIC_* 已在 shell 环境或对应 portal/.env.local 中存在。
# ═══════════════════════════════════════════════════════════════════════════════

# ── 运行环境 ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── 数据库（PostgreSQL）──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vxturestudio_platform_main
DB_POOL_MAX=10

# ── 缓存（Redis）─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── 认证 / JWT（三端 BFF 共用同一密钥，保证跨 portal token 互认）─────────────
# 生产环境必须 ≥ 32 位随机字符串
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
# 本地留空；生产设为一级域名（如 .vxture.com）实现跨子域 Cookie 共享
AUTH_COOKIE_DOMAIN=

# ── Cloudflare Turnstile（Managed，人机验证）──────────────────────────────────
# CF_TURNSTILE_ENABLED=true 后，服务端会强制校验登录、注册、短信验证码请求。
CF_TURNSTILE_ENABLED=false
NEXT_PUBLIC_CF_TURNSTILE_TENANT_SITE_KEY=
CF_TURNSTILE_TENANT_SECRET_KEY=
CF_TURNSTILE_TENANT_ALLOWED_HOSTNAMES=localhost,127.0.0.1,vxture.com,ruyin.ai
NEXT_PUBLIC_CF_TURNSTILE_ADMIN_SITE_KEY=
CF_TURNSTILE_ADMIN_SECRET_KEY=
CF_TURNSTILE_ADMIN_ALLOWED_HOSTNAMES=localhost,127.0.0.1,admin.vxture.com

# ── Portal 基址（OAuth 回调白名单 + 邮件跳转链接）────────────────────────────
WEBSITE_BASE_URL=http://localhost:3010
CONSOLE_BASE_URL=http://localhost:3020

# ── 服务端口 ──────────────────────────────────────────────────────────────────
WEBSITE_BFF_PORT=3011
CONSOLE_BFF_PORT=3021
ADMIN_BFF_PORT=3031
VELA_BFF_PORT=3121
VELA_SERVER_PORT=3122
RUYIN_BFF_PORT=3111
RUYIN_SERVER_PORT=3112
AI_GATEWAY_PORT=3100

# ── 内部服务地址（BFF → Agent Server / AI Gateway）───────────────────────────
AI_GATEWAY_URL=http://localhost:3100
VELA_SERVER_INTERNAL_URL=http://localhost:3122

# ── 邮件（阿里云 DirectMail SMTP）────────────────────────────────────────────
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=no-reply@mail.example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Vxture Studio" <no-reply@mail.example.com>

# ── 短信（阿里云 SMS）────────────────────────────────────────────────────────
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000000

# ── OAuth — 钉钉（website-bff 专用，租户用户登录；禁止用于 admin 登录）────────
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_CALLBACK_TOKEN=your-dingtalk-callback-token
DINGTALK_CALLBACK_AES_KEY=your-dingtalk-callback-aes-key
# 必须与钉钉开放平台配置的 OAuth 回调地址完全一致
# 本地：http://localhost:8000/auth-api/auth/oauth/dingtalk/callback
# 生产：https://www.vxture.com/auth-api/auth/oauth/dingtalk/callback
DINGTALK_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/dingtalk/callback

# ── OAuth — 飞书（website-bff 专用，租户用户登录；禁止用于 admin 登录）────────
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:8000/auth-api/auth/oauth/feishu/callback

# ── AI 模型（豆包 / ByteDance Ark）──────────────────────────────────────────
DOUBAO_API_KEY=your-doubao-api-key

# ── Vela 智能体 ───────────────────────────────────────────────────────────────
VELA_DEFAULT_MODEL_CODE=doubao-seed-2-0-lite-260215
# 平台运营租户 UUID（admin surface LLM 调用计费归因）
VELA_PLATFORM_LLM_TENANT_ID=your-platform-tenant-uuid
# 可选：AI Gateway 中已注册的 agent UUID；留空则按 tenantId 计量
# VELA_LLM_AGENT_ID=

# ── 可选 AI 模型（按需填写）──────────────────────────────────────────────────
# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# 通义千问（阿里云）
# QWEN_API_KEY=your-qwen-api-key

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ── 可选监控 / 分析 ───────────────────────────────────────────────────────────
# Sentry（错误追踪）
# SENTRY_DSN=https://...@sentry.io/...

# PostHog（用户行为分析）
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com
