# 用于管理环境变量的配置
# 复制此文件为 .env.local 并填入你的值

# 核心设置
NODE_ENV=development  # 环境 (development, production, test)
NEXT_PUBLIC_APP_URL=http://localhost:3000  # 应用URL

# API和后端集成
NEXT_PUBLIC_API_URL=http://localhost:8000  # 后端API基础地址
NEXT_PUBLIC_API_TIMEOUT=30000  # API超时时间 (毫秒)
NEXT_PUBLIC_API_RETRY_COUNT=3  # API重试次数

# 文件上传设置
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true  # 允许文件上传
NEXT_PUBLIC_MAX_UPLOAD_SIZE=10  # 最大上传大小 (MB)
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.md,.csv  # 允许的文件类型

# API密钥 (仅用于服务端API路由)
# 警告: 这些密钥只能在服务端组件和API路由中使用，不要暴露给客户端
OPENAI_API_KEY=sk-xxx  # OpenAI API密钥 (仅用于服务端API路由)
OPENAI_ORG_ID=  # OpenAI 组织ID
ANTHROPIC_API_KEY=  # Anthropic API密钥
DASHSCOPE_API_KEY=  # 阿里通义API密钥

# 认证设置
AUTH_SECRET=xxx  # 认证密钥，用于会话加密
NEXTAUTH_URL=http://localhost:3000  # Next Auth URL
NEXT_PUBLIC_ENABLE_AUTH=true  # 是否启用认证
NEXT_PUBLIC_ALLOW_SIGNUP=true  # 是否允许注册
NEXT_PUBLIC_DEMO_MODE=false  # 演示模式

# 数据库设置 (用于服务端API)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vxture  # 数据库连接字符串
REDIS_URL=redis://localhost:6379/0  # Redis连接字符串

# 部署和基础设施
VERCEL_URL=  # Vercel URL
NEXT_PUBLIC_VERCEL_ENV=  # Vercel 环境
VERCEL_GIT_COMMIT_SHA=  # Git提交SHA

# 国际化设置
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN  # 默认语言
NEXT_PUBLIC_AVAILABLE_LOCALES=zh-CN,en-US  # 可用语言

# 分析和监控
NEXT_PUBLIC_ANALYTICS_ID=  # 分析ID
NEXT_PUBLIC_ANALYTICS_PROVIDER=  # 分析提供商 (ga4, plausible, umami)
NEXT_PUBLIC_SENTRY_DSN=  # Sentry DSN
SENTRY_PROJECT=  # Sentry项目名称
SENTRY_ORG=  # Sentry组织
NEXT_PUBLIC_POSTHOG_KEY=  # PostHog密钥
NEXT_PUBLIC_POSTHOG_HOST=  # PostHog主机

# 调试设置
NEXT_PUBLIC_DEBUG_MODE=true  # 启用调试模式
NEXT_PUBLIC_SHOW_API_CALLS=true  # 显示API调用
NEXT_PUBLIC_SHOW_TOKENS=false  # 显示Token使用情况
