{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "vxture",
  "private": true,
  "version": "0.1.0",
  "description": "现代化企业官网平台 - Next.js 15 + FastAPI + PostgreSQL",
  "keywords": [
    "monorepo",
    "nextjs",
    "fastapi",
    "enterprise",
    "web-platform"
  ],
  "author": "vxture team",
  "license": "MIT",
  "scripts": {
    "// === 开发环境 ===": "",
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:full": "concurrently \"pnpm dev\" \"pnpm dev:api\" --names \"web,api\" --prefix-colors \"cyan,yellow\"",
    "start": "pnpm dev:full",
    "// === 构建和部署 ===": "",
    "build": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:all": "pnpm --parallel build",
    "preview": "pnpm --filter web preview",
    "// === 代码质量 ===": "",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "type-check": "pnpm --filter web type-check",
    "type-check:all": "pnpm --recursive type-check",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "// === 测试 ===": "",
    "test": "pnpm --recursive test",
    "test:watch": "pnpm --recursive test:watch",
    "test:coverage": "pnpm --recursive test:coverage",
    "// === 依赖管理 ===": "",
    "clean": "pnpm --recursive clean && rimraf node_modules",
    "clean:cache": "pnpm store prune && rimraf .turbo .next dist build",
    "reset": "pnpm clean && pnpm clean:cache && pnpm install",
    "update": "pnpm --recursive update",
    "check-deps": "pnpm audit && pnpm --recursive outdated",
    "// === 环境检查 ===": "",
    "check-env": "node -e \"console.log('Node:', process.version); console.log('PNPM:', process.env.npm_config_user_agent)\"",
    "health": "pnpm check-env && pnpm type-check && pnpm lint",
    "// === 数据库操作 ===": "",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:reset": "pnpm --filter api db:reset",
    "db:seed": "pnpm --filter api db:seed",
    "// === 部署相关 ===": "",
    "prepare": "husky install",
    "precommit": "pnpm lint:fix && pnpm type-check",
    "prepush": "pnpm health && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react-icons": "^5.5.0"
  }
}
