{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "vxture",
  "private": true,
  "version": "0.1.0",
  "description": "Vxture 大模型和智能体服务平台",
  "keywords": [
    "monorepo",
    "nextjs",
    "fastapi",
    "saas",
    "ai",
    "agents"
  ],
  "author": "vxture team",
  "license": "MIT",
  "scripts": {
    "// === 开发环境 ===": "",
    "dev": "pnpm --filter @vxture/website dev",
    "dev:gateway": "pnpm --filter @vxture/gateway dev",
    "dev:full": "concurrently \"pnpm dev\" \"pnpm dev:gateway\" --names \"website,gateway\" --prefix-colors \"cyan,yellow\"",
    "start": "pnpm dev:full",
    "// === 构建和部署 ===": "",
    "build": "pnpm --filter @vxture/website build",
    "build:gateway": "pnpm --filter @vxture/gateway build",
    "build:all": "pnpm --parallel build",
    "build:shared": "pnpm --filter @vxture/shared build",
    "build:core": "pnpm --filter @vxture/core-* build",
    "build:platform": "pnpm --filter @vxture/platform-* build",
    "build:design": "pnpm --filter @vxture/design-* build",
    "preview": "pnpm --filter @vxture/website preview",
    "// === 代码质量 ===": "",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "type-check": "pnpm --filter @vxture/website type-check",
    "type-check:all": "pnpm --recursive type-check",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "// === 测试 ===": "",
    "test": "pnpm --recursive test",
    "test:watch": "pnpm --recursive test:watch",
    "test:coverage": "pnpm --recursive test:coverage",
    "// === 依赖管理 ===": "",
    "clean": "pnpm --recursive clean && rimraf node_modules",
    "clean:cache": "pnpm store prune && rimraf .turbo .next dist build",
    "reset": "pnpm clean && pnpm clean:cache && pnpm install",
    "update": "pnpm --recursive update",
    "check-deps": "pnpm audit && pnpm --recursive outdated",
    "// === 环境检查 ===": "",
    "check-env": "node -e \"console.log('Node:', process.version); console.log('PNPM:', process.env.npm_config_user_agent)\"",
    "health": "pnpm check-env && pnpm type-check && pnpm lint",
    "// === 数据库操作 ===": "",
    "db:migrate": "pnpm --filter @vxture/gateway db:migrate",
    "db:reset": "pnpm --filter @vxture/gateway db:reset",
    "db:seed": "pnpm --filter @vxture/gateway db:seed",
    "// === 部署相关 ===": "",
    "prepare": "husky || true",
    "precommit": "pnpm lint:fix && pnpm type-check",
    "prepush": "pnpm health && pnpm test"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/express": "^4.17.25",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "express": "^4.22.1"
  }
}
