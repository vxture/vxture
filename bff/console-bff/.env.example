# ================================================================
# @vxture/bff-console — 环境变量示例
# ================================================================
# 复制本文件为 .env.local，填入真实值后启动服务。
# .env.local 已加入 .gitignore，请勿提交含真实密钥的文件。
# ================================================================

# ── 运行时 ──────────────────────────────────────────────────────
NODE_ENV=development
CONSOLE_BFF_PORT=3021
LOG_LEVEL=info

# ── JWT 认证（必填）────────────────────────────────────────────
# JWT_SECRET 必须与 website-bff / admin-bff 保持一致（三端共用同一密钥验签）
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
JWT_BLACKLIST_STORAGE=redis
BCRYPT_ROUNDS=12

# ── Cookie 域（跨子域共享必填）─────────────────────────────────
# 生产示例：AUTH_COOKIE_DOMAIN=.vxture.com
# 本地开发留空
AUTH_COOKIE_DOMAIN=

# ── 数据库（必填其一）──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vxture

# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vxture
# DB_USER=postgres
# DB_PASSWORD=password
# DB_POOL_MAX=10
# DB_SSL=prefer

# ── Redis（必填，用于 JWT 黑名单）──────────────────────────────
REDIS_URL=redis://localhost:6379

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── SMTP 邮件（选填；未配置则以 no-op 模式运行，不发邮件）──────
# 用于向租户发送订阅操作确认邮件（升级 / 暂停 / 恢复 / 取消）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Vxture <noreply@example.com>
