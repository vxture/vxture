{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@vxture/bff-tenant/*": ["./src/*"],
      "@vxture/shared/*": ["../packages/shared/shared/src/*"],
      "@vxture/core-*/*": ["../packages/core/*/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
