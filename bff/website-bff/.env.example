# ================================================================
# @vxture/bff-website — 环境变量示例
# ================================================================
# 复制本文件为 .env.local，填入真实值后启动服务。
# .env.local 已加入 .gitignore，请勿提交含真实密钥的文件。
# ================================================================

# ── 运行时 ──────────────────────────────────────────────────────
NODE_ENV=development
WEBSITE_BFF_PORT=3011
LOG_LEVEL=info

# ── JWT 认证（必填）────────────────────────────────────────────
# JWT_SECRET 生产环境必须 ≥ 32 位随机字符串
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
# 令牌黑名单存储后端：redis（生产）| memory（仅开发/测试）
JWT_BLACKLIST_STORAGE=redis
BCRYPT_ROUNDS=12

# ── Cookie 域（跨子域共享必填）─────────────────────────────────
# 生产示例：AUTH_COOKIE_DOMAIN=.vxture.com
# 本地开发留空，浏览器自动使用当前域
AUTH_COOKIE_DOMAIN=

# ── 数据库（必填其一）──────────────────────────────────────────
# 方式一：完整连接 URL（推荐）
DATABASE_URL=postgresql://postgres:password@localhost:5432/vxture

# 方式二：分项配置（DATABASE_URL 未设置时生效）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vxture
# DB_USER=postgres
# DB_PASSWORD=password
# DB_POOL_MAX=10
# DB_SSL=prefer

# ── Redis（必填，用于 JWT 黑名单 + 验证码限流）──────────────────
# 方式一：连接 URL（推荐）
REDIS_URL=redis://localhost:6379

# 方式二：分项配置（REDIS_URL 未设置时生效）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── 阿里云 SMTP 邮件（必填，发送验证码/密码重置邮件）────────────
# 未配置 SMTP_PASS 时自动降级为 ConsoleMailProvider（仅打印日志）
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=no-reply@mail.vxture.com
SMTP_PASS=V2xQ7kR9pT
SMTP_FROM="vxture studio" <no-reply@mail.vxture.com>

# ── 前端地址（密码重置邮件链接使用）────────────────────────────
WEBSITE_BASE_URL=http://localhost:3010

# ── 钉钉三方登录 / 回调（仅 website + console 账号体系使用）────
# 禁止用于 admin 登录；admin 只能使用平台管理员账号体系。
# 企业内部应用通常使用 APP_KEY / APP_SECRET。
# 第三方企业应用通常使用 SUITE_KEY / SUITE_SECRET。
DINGTALK_APP_KEY=dingkfmmmskpg0hptumz
DINGTALK_APP_SECRET=d6b3Oxl8AGtNZhQclBifz8rp27FEwTqv1MlOPZgFxfJQw4yPgMy5lNCNVl8WDcmM
DINGTALK_SUITE_KEY=dingkfmmmskpg0hptumz
DINGTALK_SUITE_SECRET=d6b3Oxl8AGtNZhQclBifz8rp27FEwTqv1MlOPZgFxfJQw4yPgMy5lNCNVl8WDcmM

# 钉钉事件回调加解密配置。
DINGTALK_CALLBACK_TOKEN=5gkotyp9pukBPSkfK4QcwWtwtM4Xo8TaLx49sxw4NBDmK
DINGTALK_CALLBACK_AES_KEY=HBeIpjYVIISaqQbqS1c2A1SInmnixfOeEF5ek6iD1mi

# 必须与钉钉开放平台配置的 OAuth 回调地址完全一致。
# 生产示例：https://www.vxture.com/website-api/api/auth/oauth/dingtalk/callback
# 本地网关示例：http://localhost:8000/website-api/api/auth/oauth/dingtalk/callback
DINGTALK_REDIRECT_URI=https://www.vxture.com/website-api/api/auth/oauth/dingtalk/callback